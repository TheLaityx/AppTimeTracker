{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "应用时长",
  "version": "1.0.0",
  "identifier": "com.apptimetracker.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "应用时长",
        "width": 420,
        "height": 720,
        "minWidth": 320,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "skipTaskbar": false,
        "alwaysOnTop": false
      }
    ],

    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    },
    "publisher": "AppTimeTracker",
    "copyright": "2025 AppTimeTracker",
    "longDescription": "一款轻量的Windows应用使用时长追踪软件，支持7天/30天统计图表，开机自启，系统托盘后台运行。",
    "shortDescription": "应用使用时长追踪器"
  }
}
